APP_NAME="MI Metal Industries"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Africa/Cairo
APP_URL=http://localhost

APP_LOCALE=ar
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ar_EG

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ----------------------------------------------------------
# Database
# ----------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=mi_contracts
DB_USERNAME=root
DB_PASSWORD=

# ----------------------------------------------------------
# Cache / Session / Queue
# ----------------------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
QUEUE_CONNECTION=database
CACHE_STORE=database
FILESYSTEM_DISK=local

# ----------------------------------------------------------
# Mail
# ----------------------------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@mi-cnc.com"
MAIL_FROM_NAME="${APP_NAME}"

# ----------------------------------------------------------
# Optional integrations (WhatsApp / Resend)
# ----------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
RESEND_API_KEY=
